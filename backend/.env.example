# Copy to `backend/.env` or repo-root `.env` (duplicate keys: backend/.env wins).

# Optional — comma-separated extra CORS origins for browser clients (e.g. https://yourname.github.io).
# CORS_ORIGINS=https://yourname.github.io

# Required for AI summary (`POST /api/summarize`, chat).
OPENAI_API_KEY=

# Optional — OpenAI-compatible Chat Completions base URL (no trailing path beyond /v1).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional — model id for summarize + chat.
# SUMMARIZE_MODEL=gpt-4o-mini

# Optional — Bilibili login cookie so `/x/player/v2` returns subtitles（含 aisubtitle AI 字幕）；可从浏览器导出 Cookie 首段。
# BILIBILI_COOKIE=SESSDATA=xxx; buvid3=xxx
# Optional — YouTube Data API（部分字幕列表等辅助路径，见代码与文档）。
# YOUTUBE_DATA_API_KEY=

